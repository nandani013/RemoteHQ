generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  CONTACTED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}


model Lead {
  id         String     @id @default(uuid())
  name       String
  company    String
  email      String
  phone      String?
  status     LeadStatus @default(NEW)
  dealValue  Float      @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  Customer   Customer?
  deals      Deal[]
  tasks      CrmTask[]
  
  transcripts     CallTranscript[]
  insights        ConversationInsight[]
  salesTasks      SalesTask[]
  recommendations FollowUpRecommendation[]
  emails          GeneratedEmail[]
}

model Customer {
  id         String   @id @default(uuid())
  leadId     String   @unique
  lead       Lead     @relation(fields: [leadId], references: [id])
  name       String
  company    String
  email      String
  phone      String?
  createdAt  DateTime @default(now())

  deals      Deal[]
}

model Deal {
  id         String     @id @default(uuid())
  leadId     String
  lead       Lead       @relation(fields: [leadId], references: [id])
  customerId String?
  customer   Customer?  @relation(fields: [customerId], references: [id])

  amount     Float      @default(0)
  status     LeadStatus @default(NEW)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Ticket {
  id          String       @id @default(uuid())
  title       String
  description String
  status      TicketStatus @default(OPEN)
  assignedTo  String?
  createdAt   DateTime     @default(now())
}

model Activity {
  id          String   @id @default(uuid())
  description String
  type        String   @default("GENERAL")
  createdAt   DateTime @default(now())
}

model ActivityLog {
  id          String   @id @default(uuid())
  description String
  type        String   @default("GENERAL")
  createdAt   DateTime @default(now())
}

// ==========================================
// Authentication Models
// ==========================================
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // bcrypt hash
  name      String?
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CrmTask {
  id          String   @id @default(uuid())
  title       String
  owner       String   @default("Unassigned")
  dueDate     String?
  status      String   @default("OPEN")
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id])
  createdAt   DateTime @default(now())
}
model CallTranscript {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id])
  transcript String
  createdAt DateTime @default(now())
  
  insights ConversationInsight[]
}

model ConversationInsight {
  id               String   @id @default(uuid())
  leadId           String?
  lead             Lead?    @relation(fields: [leadId], references: [id])
  callTranscriptId String?
  callTranscript   CallTranscript? @relation(fields: [callTranscriptId], references: [id])
  insights         String   // JSON string of insights
  createdAt        DateTime @default(now())
}

model SalesTask {
  id        String   @id @default(uuid())
  title     String
  owner     String   @default("Unassigned")
  dueDate   String?
  status    String   @default("OPEN")
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id])
  createdAt DateTime @default(now())
}

model FollowUpRecommendation {
  id             String   @id @default(uuid())
  leadId         String
  lead           Lead     @relation(fields: [leadId], references: [id])
  recommendation String
  createdAt      DateTime @default(now())
}

model GeneratedEmail {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id])
  subject   String
  body      String
  createdAt DateTime @default(now())
}
